<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- ==================== Properties ==================== -->
    <springProperty name="APP_NAME" source="spring.application.name" defaultValue="agent-platform"/>
    <property name="LOG_PATH" value="logs"/>
    <property name="PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n"/>

    <!-- ==================== Appenders ==================== -->

    <!-- 1. 接口交互: Controller 层 -->
    <appender name="API" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/api.log</file>
        <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
            <evaluator class="ch.qos.logback.classic.boolex.OnMarkerEvaluator">
                <marker>API</marker>
            </evaluator>
            <onMismatch>DENY</onMismatch>
            <onMatch>ACCEPT</onMatch>
        </filter>
        <encoder>
            <pattern>${PATTERN}</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/api.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- 2. 业务操作: Service 层 -->
    <appender name="BIZ" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/biz.log</file>
        <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
            <evaluator class="ch.qos.logback.classic.boolex.OnMarkerEvaluator">
                <marker>BIZ</marker>
            </evaluator>
            <onMismatch>DENY</onMismatch>
            <onMatch>ACCEPT</onMatch>
        </filter>
        <encoder>
            <pattern>${PATTERN}</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/biz.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- 3. 数据操作: Infrastructure 层（DB/OSS/外部API） -->
    <appender name="DATA" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/data.log</file>
        <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
            <evaluator class="ch.qos.logback.classic.boolex.OnMarkerEvaluator">
                <marker>DATA</marker>
            </evaluator>
            <onMismatch>DENY</onMismatch>
            <onMatch>ACCEPT</onMatch>
        </filter>
        <encoder>
            <pattern>${PATTERN}</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/data.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- 4. 系统运行: 框架/容器/通用日志 -->
    <appender name="SYS" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/sys.log</file>
        <encoder>
            <pattern>${PATTERN}</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/sys.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- 5. 控制台: 同步输出以上全部 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%thread] %cyan(%logger{36}) - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ==================== Logger 分配 ==================== -->

    <!-- 接口交互 -->
    <logger name="com.ma.agent.chat.api" level="INFO" additivity="false">
        <appender-ref ref="API"/>
        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="com.ma.agent.knowledge.api" level="INFO" additivity="false">
        <appender-ref ref="API"/>
        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="com.ma.agent.system.api" level="INFO" additivity="false">
        <appender-ref ref="API"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- 业务操作 -->
    <logger name="com.ma.agent.chat.application" level="INFO" additivity="false">
        <appender-ref ref="BIZ"/>
        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="com.ma.agent.knowledge.application" level="INFO" additivity="false">
        <appender-ref ref="BIZ"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- 数据操作: Gateway/OSS/DB 等 -->
    <logger name="com.ma.agent.model.infrastructure" level="INFO" additivity="false">
        <appender-ref ref="DATA"/>
        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="com.ma.agent.knowledge.infrastructure" level="INFO" additivity="false">
        <appender-ref ref="DATA"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- 系统运行 -->
    <root level="INFO">
        <appender-ref ref="SYS"/>
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
