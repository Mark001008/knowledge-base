<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ma.kb.dal.mapper.document.DocumentMapper">

    <!-- 统计知识库下的文档数量 -->
    <select id="countBySpaceId" resultType="int">
        SELECT COUNT(1)
        FROM kb_document d
        WHERE d.space_id = #{spaceId}
    </select>

</mapper>
